APP_ENV=local
APP_VERSION=0.1.0

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+psycopg://md_converter:md_converter@localhost:5432/md_converter
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_UPLOADS=uploads
S3_BUCKET_OUTPUTS=outputs
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
SIGNED_URL_TTL_SECONDS=3600

MAX_UPLOAD_SIZE_BYTES=524288000
MAX_PDF_PAGES=1000
MAX_PPTX_SLIDES=500
DEFAULT_PDF_BATCH_SIZE=20
DEFAULT_OCR_BATCH_SIZE=5

TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata/
DOCLING_MODEL_CACHE=/app/.cache/docling
HF_HOME=/app/.cache/huggingface
SENTRY_DSN=

